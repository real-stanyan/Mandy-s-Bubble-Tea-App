# Backend API base (Next.js). In dev, point at your local tunnel/lan
# address so the device can hit /api/me etc. (e.g. https://xxx.ngrok.app).
EXPO_PUBLIC_API_BASE_URL=https://mandybubbletea.com

# Supabase — same project as the web app.
EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Google Sign-In (Phase 3b) — Web client ID is what Supabase verifies
# against, iOS client ID is what the native SDK uses at runtime.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
